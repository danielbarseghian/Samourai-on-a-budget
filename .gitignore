# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
.utmp/
/Samourai-on-a-budget/[Ll]ibrary/
/Samourai-on-a-budget/[Tt]emp/
/Samourai-on-a-budget/[Oo]bj/
/Samourai-on-a-budget/[Bb]uild/
/Samourai-on-a-budget/[Bb]uilds/
/Samourai-on-a-budget/[Ll]ogs/
/Samourai-on-a-budget/[Uu]ser[Ss]ettings/
*.log
# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta
# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Samourai-on-a-budget/[Mm]emoryCaptures/
# Recordings can get excessive in size
/Samourai-on-a-budget/[Rr]ecordings/
# Uncomment this line if you wish to ignore the asset store tools plugin
# /Samourai-on-a-budget/[Aa]ssets/AssetStoreTools*
# Autogenerated Jetbrains Rider plugin
/Samourai-on-a-budget/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user
# Visual Studio cache directory
.vs/
# Gradle cache directory
.gradle/
# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta
# Unity3D generated file on crash reports
sysinfo.txt
# Mono auto generated files
mono_crash.*
# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
# Crashlytics generated file
crashlytics-build.properties
# TestRunner generated files
InitTestScene*.unity*
# Addressables default ignores, before user customizations
/Samourai-on-a-budget/ServerData
/Samourai-on-a-budget/[Aa]ssets/StreamingAssets/aa*
/Samourai-on-a-budget/[Aa]ssets/AddressableAssetsData/link.xml*
/Samourai-on-a-budget/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Samourai-on-a-budget/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/Samourai-on-a-budget/[Aa]ssets/AddressableAssetsData/*/*.bin*
# Visual Scripting auto-generated files
/Samourai-on-a-budget/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/Samourai-on-a-budget/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/Samourai-on-a-budget/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/Samourai-on-a-budget/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
# Auto-generated scenes by play mode tests
/Samourai-on-a-budget/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
# Auto-generated cache in Assets folder
/Samourai-on-a-budget/[Aa]ssets/[Ss]ceneDependencyCache*
